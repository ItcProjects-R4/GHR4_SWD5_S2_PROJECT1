@model IEnumerable<Opportunity>
@{ ViewData["Title"] = "Opportunities"; ViewData["ActiveNav"] = "Opportunities"; Layout = "~/Views/Shared/_AppLayout.cshtml"; }

<div class="grid grid-2">
    @foreach (var opp in Model)
    {
        var bc   = opp.Type == "Job" ? "badge-primary" : opp.Type == "Internship" ? "badge-warm" : "badge-outline";
        var tags = (opp.RequiredSkills ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries);
        <div class="card card-hover">
            <div class="flex-between">
                <span class="badge @bc">@opp.Type</span>
                <span class="text-xs text-muted">@opp.CreatedAt.ToString("MMM d")</span>
            </div>
            <h3 class="mt-3" style="font-size:17px;">@opp.Title</h3>
            <div class="text-sm text-muted mt-1">@opp.Source</div>
            <div class="flex gap-2 mt-3" style="flex-wrap:wrap;">
                @foreach (var tag in tags) { <span class="badge">@tag.Trim()</span> }
            </div>
            @if (!string.IsNullOrEmpty(opp.Link))
            {
                <a href="@opp.Link" target="_blank" rel="noopener" class="btn btn-primary btn-sm mt-4">Apply →</a>
            }
        </div>
    }
</div>
