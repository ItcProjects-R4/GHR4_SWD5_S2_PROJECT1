<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] — Pathway</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,600;9..144,700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/pathway.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
</head>
<body>
    @if (TempData["Success"] != null)
    {
        <div class="flash flash-success">@TempData["Success"]</div>
    }
    @if (TempData["Info"] != null)
    {
        <div class="flash flash-info">@TempData["Info"]</div>
    }

    @RenderBody()

    <script src="~/js/pathway.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
