@model StudentDashboardViewModel
@{ ViewData["Title"] = "Dashboard"; ViewData["ActiveNav"] = "Dashboard"; Layout = "~/Views/Shared/_AppLayout.cshtml"; }

<div class="grid grid-4">
    <div class="kpi"><div class="label">Enrolled courses</div><div class="val">@Model.EnrolledCoursesCount</div></div>
    <div class="kpi"><div class="label">In progress</div><div class="val">@Model.InProgressCount</div></div>
    <div class="kpi"><div class="label">Completed</div><div class="val">@Model.CompletedCount</div></div>
    <div class="kpi">
        <div class="label">Overall progress</div>
        <div class="val">@Model.OverallProgressPercent%</div>
        <div class="progress mt-2"><div style="width:@Model.OverallProgressPercent%"></div></div>
    </div>
</div>

<div class="grid grid-2 mt-6">
    <!-- Continue learning -->
    <div class="card">
        <div class="flex-between">
            <h3 style="font-size:17px;">Continue learning</h3>
            <a asp-controller="Student" asp-action="MyCourses" class="text-sm" style="color:var(--primary);">View all →</a>
        </div>
        @if (Model.ContinueLearning.Any())
        {
            foreach (var item in Model.ContinueLearning)
            {
                var cls = item.Enrollment.Status == "completed" ? "badge-success"
                        : item.Enrollment.Status == "in-progress" ? "badge-warm" : "badge-outline";
                <div class="mt-4">
                    <div class="flex-between">
                        <div>
                            <div style="font-weight:500;font-size:14px;">@item.Course?.Title</div>
                            <div class="text-xs text-muted">@(item.Track?.Name ?? "—")</div>
                        </div>
                        <span class="badge @cls">@item.Enrollment.Status</span>
                    </div>
                    <div class="progress mt-2"><div style="width:@((int)item.Enrollment.ProgressPercentage)%"></div></div>
                </div>
            }
        }
        else
        {
            <p class="text-sm text-muted mt-4">No courses yet. <a asp-controller="Student" asp-action="Initiatives" style="color:var(--primary);">Explore initiatives →</a></p>
        }
    </div>

    <!-- Recommended -->
    <div class="card">
        <h3 style="font-size:17px;">Recommended tracks</h3>
        @if (Model.RecommendedTracks.Any())
        {
            foreach (var track in Model.RecommendedTracks)
            {
                <div class="flex-between mt-4">
                    <div>
                        <div style="font-weight:500;font-size:14px;">@track.Name</div>
                        <div class="text-xs text-muted">@(track.Initiative?.Name ?? "") · @(track.Type ?? "")</div>
                    </div>
                    <form asp-controller="Student" asp-action="EnrollTrack" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="trackId" value="@track.Id" />
                        <button type="submit" class="btn btn-outline btn-sm">Join</button>
                    </form>
                </div>
            }
        }
        else
        {
            <p class="text-sm text-muted mt-4">You've explored all available tracks!</p>
        }
    </div>
</div>

@if (Model.MyTracks.Any())
{
    <div class="card mt-6">
        <div class="flex-between">
            <h3 style="font-size:17px;">Your tracks</h3>
            <a asp-controller="Student" asp-action="MyTracks" class="text-sm" style="color:var(--primary);">View all →</a>
        </div>
        <div class="grid grid-3 mt-4">
            @foreach (var tc in Model.MyTracks)
            {
                <div class="card card-hover" style="border:1px solid var(--border);">
                    <div class="text-xs text-muted">@(tc.Track.Initiative?.Name ?? "")</div>
                    <div style="font-weight:600;margin-top:4px;">@tc.Track.Name</div>
                    <div class="text-xs text-muted mt-2">@tc.CoursesCount courses · @tc.ProgressPercent% done</div>
                    <div class="progress mt-2"><div style="width:@tc.ProgressPercent%"></div></div>
                    <a asp-controller="Student" asp-action="TrackCourses" asp-route-trackId="@tc.Track.Id"
                       class="btn btn-outline btn-sm mt-4">Open</a>
                </div>
            }
        </div>
    </div>
}
