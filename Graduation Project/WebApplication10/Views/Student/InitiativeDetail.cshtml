@model InitiativeDetailViewModel
@{ ViewData["Title"] = Model.Initiative.Name; ViewData["ActiveNav"] = "Initiatives"; Layout = "~/Views/Shared/_AppLayout.cshtml"; }

<a asp-controller="Student" asp-action="Initiatives" class="text-sm text-muted">← All initiatives</a>

<div class="card mt-4">
    <span class="badge">Initiative</span>
    <h2 style="font-size:28px;margin-top:8px;">@Model.Initiative.Name</h2>
    <p class="text-muted mt-2">@Model.Initiative.Description</p>
</div>

<h3 class="mt-6" style="font-size:18px;">Tracks (@Model.Tracks.Count)</h3>

<div class="grid grid-2 mt-4">
    @foreach (var item in Model.Tracks)
    {
        <div class="card card-hover">
            <div class="flex-between">
                <span class="badge badge-outline">@(item.Track.Type ?? "General")</span>
                <span class="text-xs text-muted">@item.CourseCount courses</span>
            </div>
            <h3 class="mt-4" style="font-size:17px;">@item.Track.Name</h3>
            <p class="text-sm text-muted mt-2">@item.Track.Description</p>
            <div class="flex gap-2 mt-5">
                @if (item.IsEnrolled)
                {
                    <a asp-controller="Student" asp-action="TrackCourses" asp-route-trackId="@item.Track.Id"
                       class="btn btn-primary btn-sm">Open track</a>
                    <form asp-controller="Student" asp-action="LeaveTrack" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="trackId" value="@item.Track.Id" />
                        <input type="hidden" name="returnUrl" value="@Url.Action("InitiativeDetail","Student",new{id=Model.Initiative.Id})" />
                        <button type="submit" class="btn btn-outline btn-sm">Leave</button>
                    </form>
                }
                else
                {
                    <form asp-controller="Student" asp-action="EnrollTrack" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="trackId" value="@item.Track.Id" />
                        <input type="hidden" name="returnUrl" value="@Url.Action("InitiativeDetail","Student",new{id=Model.Initiative.Id})" />
                        <button type="submit" class="btn btn-primary btn-sm">Join track</button>
                    </form>
                }
            </div>
        </div>
    }
</div>
