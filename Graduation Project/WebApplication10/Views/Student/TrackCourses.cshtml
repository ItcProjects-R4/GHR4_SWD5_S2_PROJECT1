@model TrackCoursesViewModel
@{ ViewData["Title"] = Model.Track.Name; ViewData["ActiveNav"] = "MyTracks"; Layout = "~/Views/Shared/_AppLayout.cshtml"; }

<a asp-controller="Student" asp-action="MyTracks" class="text-sm text-muted">← My tracks</a>

<div class="card mt-4">
    <h2 style="font-size:24px;">@Model.Track.Name</h2>
    <p class="text-muted mt-2">@Model.Track.Description</p>
</div>

@Html.AntiForgeryToken()

<div class="grid grid-2 mt-6">
    @foreach (var item in Model.Courses)
    {
        var pct = (int)item.Enrollment.ProgressPercentage;
        var cls = item.Enrollment.Status == "completed"   ? "badge-success"
                : item.Enrollment.Status == "in-progress" ? "badge-warm"
                : "badge-outline";
        <div class="card">
            <div class="flex-between">
                <div style="font-weight:600;">@item.Course.Title</div>
                <span class="badge @cls" id="status-@item.Enrollment.Id">@item.Enrollment.Status</span>
            </div>
            <div class="text-xs text-muted mt-1">@item.Course.Duration &nbsp;·&nbsp; @item.Course.SourceType</div>
            <div class="mt-4">
                <div class="flex-between text-sm">
                    <span>Progress</span>
                    <span id="pct-@item.Enrollment.Id">@pct%</span>
                </div>
                <input type="range" min="0" max="100" value="@pct"
                       class="mt-2" style="width:100%;"
                       oninput="document.getElementById('pct-@item.Enrollment.Id').textContent=this.value+'%'"
                       onchange="updateProgress(@item.Enrollment.Id,this.value)" />
            </div>
            @if (!string.IsNullOrEmpty(item.Course.ContentUrl))
            {
                <a href="@item.Course.ContentUrl" target="_blank" rel="noopener"
                   class="btn btn-outline btn-sm mt-4">View course →</a>
            }
        </div>
    }
</div>
