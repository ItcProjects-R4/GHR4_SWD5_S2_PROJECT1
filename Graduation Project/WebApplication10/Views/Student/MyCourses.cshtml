@* ============================================================
   Views/Student/MyCourses.cshtml
   ============================================================ *@
@model IEnumerable<PathwayPlatform.Models.ViewModels.CourseEnrollmentPair>
@{
    ViewData["Title"]     = "My Courses";
    ViewData["ActiveNav"] = "Courses";
    Layout = "~/Views/Shared/_AppLayout.cshtml";
}

@Html.AntiForgeryToken()

@if (!Model.Any())
{
    <div class="card">
        <p class="text-muted">Join a track to see courses here.</p>
        <a asp-controller="Student" asp-action="Initiatives" class="btn btn-primary mt-4">Browse initiatives</a>
    </div>
}
else
{
    <div class="grid grid-2">
        @foreach (var pair in Model)
        {
            var en  = pair.Enrollment;
            var c   = pair.Course;
            var pct = (int)en.ProgressPercentage;
            var cls = en.Status == "completed"   ? "badge-success"
                    : en.Status == "in-progress"  ? "badge-warm"
                    : "badge-outline";

            <div class="card">
                <div class="flex-between">
                    <div>
                        <div style="font-weight:600;">@c.Title</div>
                        <div class="text-xs text-muted">@c.Track?.Name</div>
                    </div>
                    <span class="badge @cls">@en.Status</span>
                </div>

                <div class="text-xs text-muted mt-1">@c.Duration &nbsp;·&nbsp; @c.SourceType</div>

                <div class="mt-4">
                    <div class="flex-between text-sm">
                        <span>Progress</span>
                        <span id="pct-@en.Id">@pct%</span>
                    </div>
                    <input type="range" min="0" max="100" value="@pct"
                           class="mt-2" style="width:100%;"
                           oninput="document.getElementById('pct-@en.Id').textContent=this.value+'%'"
                           onchange="updateProgress(@en.Id, this.value)" />
                </div>

                @if (!string.IsNullOrEmpty(c.ContentUrl))
                {
                    <a href="@c.ContentUrl" target="_blank" rel="noopener"
                       class="btn btn-outline btn-sm mt-4">View course →</a>
                }
            </div>
        }
    </div>
}

@section Scripts {
<script>
    function updateProgress(enrollmentId, value) {
        var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
        fetch('/Student/UpdateProgress', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': token
            },
            body: JSON.stringify({ enrollmentId: parseInt(enrollmentId), progress: parseInt(value) })
        }).catch(function(err) { console.warn('UpdateProgress failed:', err); });
    }
</script>
}
