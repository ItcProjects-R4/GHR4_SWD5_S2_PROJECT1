@model Initiative
@{ ViewData["Title"] = "New Initiative"; ViewData["ActiveNav"] = "Initiatives"; Layout = "~/Views/Shared/_AppLayout.cshtml"; }

<div class="card" style="max-width:600px;">
    <div class="flex-between mb-4">
        <a asp-controller="Admin" asp-action="Initiatives" class="text-sm text-muted">← Initiatives</a>
    </div>
    <h3 style="font-size:19px;">New Initiative</h3>
    <form asp-controller="Admin" asp-action="CreateInitiative" method="post" class="mt-5">
        @Html.AntiForgeryToken()
        <div class="field">
            <label asp-for="Name">Name <span style="color:var(--destructive)">*</span></label>
            <input asp-for="Name" required />
            <span asp-validation-for="Name" class="field-error"></span>
        </div>
        <div class="field">
            <label asp-for="Description">Description</label>
            <textarea asp-for="Description" rows="3"></textarea>
        </div>
        <div class="flex gap-3 mt-5">
            <button class="btn btn-primary" type="submit">Create</button>
            <a asp-controller="Admin" asp-action="Initiatives" class="btn btn-outline">Cancel</a>
        </div>
    </form>
</div>
